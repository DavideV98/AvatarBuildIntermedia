# =========================
# SERVER AVATAR / NeMo
# =========================
HOST=0.0.0.0
PORT=8000
NEMO_URL=http://127.0.0.1:8000
STT_TIMEOUT_S=60.0

# =========================
# AUDIO INPUT / VAD / DSP
# =========================
# DEVICE=0
CHANNELS=1
SAMPLERATE=48000

FRAME_MS=30
VAD_AGGR=2
PRE_ROLL_MS=300
SILENCE_MS=500
MIN_SPEECH_MS=650
MAX_SEGMENT_S=12.0

HP_CUTOFF=80.0
GATE=0.012

# =========================
# OUTPUT / LOG
# =========================
OUT_DIR=recordings
TEST_OUT_DIR=test_outputs
LOG_FILE=latency_log.jsonl
SAMPLE_WAV=sample.wav

# =========================
# LLM / ORCHESTRATOR
# =========================
ANGY_ROUTER_MODEL=gpt-4o-mini
ANGY_AGENT_MODEL=gpt-4o-mini
ANGY_EMBED_MODEL=text-embedding-3-small

# =========================
# RAG
# =========================
RAG_DIR=rag
RAG_INDEX=contenuti_faiss_index.faiss
RAG_METADATA=contenuti_metadata.pkl
RAG_TOP_K=5

# =========================
# LANGUAGE
# =========================
LANGUAGE=it

# =========================
# TTS CLIENT CHUNKING
# pipeline definitiva: un solo request TTS
# =========================
TTS_CHUNKING=0
TTS_CHUNK_CHARS=90
TTS_FIRST_CHUNK_CHARS=45

# =========================
# VIBEVOICE BRIDGE
# =========================
VIBEVOICE_URL=http://127.0.0.1:8001
VIBEVOICE_TIMEOUT_S=180.0

# voce richiesta dal client Python
VV_SPEAKER_NAME=it-Spk0_woman
VV_VOICE_PRESET=vibevoice_bridge/voices/it-Spk0_woman.pt

# runtime bridge
VIBEVOICE_MODEL_PATH=microsoft/VibeVoice-Realtime-0.5B
VIBEVOICE_DEVICE=cuda
VIBEVOICE_ATTN_IMPL=flash_attention_2
VIBEVOICE_DDPM_STEPS=10
VIBEVOICE_CFG_SCALE=1.5
VIBEVOICE_CHUNK_MS=33
VIBEVOICE_SAMPLE_RATE=24000
VIBEVOICE_PORT=8001

# preset default lato bridge/container
VIBEVOICE_VOICE_PATH=/app/vibevoice_bridge/voices/it-Spk0_woman.pt
VIBEVOICE_VOICES_DIR=/app/vibevoice_bridge/voices

# prewarm VV
VIBEVOICE_PREWARM=1
VIBEVOICE_PREWARM_SPEAKER_NAME=it-Spk0_woman
VIBEVOICE_PREWARM_TEXT=Ciao, questo è un prewarm.

# =========================
# UNREAL PCM ENDPOINT
# host-side (il compose lo overridea nel container)
# =========================
UNREAL_PCM_URL=http://127.0.0.1:7777/ace/audio_samples
UNREAL_HTTP_TIMEOUT_S=60

# =========================
# UNREAL ACK CALLBACK
# =========================
ACK_HOST=127.0.0.1
ACK_PORT=9998
ACK_ROUTE=/playback_done
ACK_TIMEOUT_S=120.0
MIC_RESUME_PAD_MS=300

# 0 = aspetta ACK finale prima di riaprire il microfono
# 1 = non aspetta ACK
DISABLE_MIC_GATING=0

DEVICE=1